# Database
# Connect to your existing PostgreSQL instance on the Pi (default: 5432)
# E.g., postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/shared_lists"

# NextAuth Configuration
# The base URL of your application (e.g. http://192.168.1.100:3000 or your Tailscale IP URL)
NEXTAUTH_URL="http://localhost:3000"
# A random string used to encrypt the NextAuth.js JWTs and session tokens
# You can generate one via: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-replace-me"

# Email Configuration (Optional - for inviting via email link)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
SMTP_FROM="Shared Lists <your-email@example.com>"
